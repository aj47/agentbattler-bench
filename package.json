{
  "name": "agentbattler-bench",
  "version": "0.1.0",
  "private": true,
  "description": "Public, replayable chess-agent harness benchmark proof loop",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test",
    "validate": "node bin/agentbattler.mjs validate",
    "benchmark": "node bin/agentbattler.mjs run",
    "replay": "node bin/agentbattler.mjs replay",
    "pack:result": "node bin/agentbattler.mjs pack",
    "export:hf-results": "node scripts/export-hf-results.mjs export",
    "verify:hf-results": "node scripts/export-hf-results.mjs verify",
    "publish:hf-results": "node scripts/publish-hf-results.mjs",
    "export:hf-dotagents": "node scripts/export-hf-results.mjs export --suite-set dotagents",
    "verify:hf-dotagents": "node scripts/export-hf-results.mjs verify --suite-set dotagents",
    "test:hf-results": "node --test tests/compressed-result.test.mjs",
    "generate:model-suite": "node scripts/generate-model-suite.mjs",
    "validate:model-suite": "node bin/agentbattler.mjs validate --manifest agents/model-suite/manifest.json --pairing all-pairs",
    "benchmark:model-suite": "node bin/agentbattler.mjs run --manifest agents/model-suite/manifest.json --pairing all-pairs --output results/model-suite/matches --no-smoke",
    "league:import:model-suite": "node scripts/import-snapshot-ledger.mjs",
    "league:import:published": "node scripts/import-results-ledger.mjs",
    "replay:model-suite": "node scripts/replay-snapshot.mjs",
    "replay:snapshot": "node scripts/replay-snapshot.mjs",
    "replay:published:model-suite": "node scripts/replay-snapshot.mjs --tournament codex-within-harness",
    "replay:published:pi-suite": "node scripts/replay-snapshot.mjs --tournament pi-within-harness",
    "replay:published:harness-suite": "node scripts/replay-snapshot.mjs --tournament cross-harness-all",
    "pi:image": "docker build --tag agentbattler-pi:0.80.7 --build-arg PI_VERSION=0.80.7 harnesses/pi",
    "generate:pi-suite": "node scripts/generate-pi-suite.mjs",
    "generate:pi-suite:resume": "AGENTBATTLER_RESUME=1 node scripts/generate-pi-suite.mjs",
    "validate:pi-suite": "node bin/agentbattler.mjs validate --manifest agents/pi-model-suite/manifest.json --positions benchmark/positions/v2.json --pairing cross-model",
    "benchmark:pi-suite": "AGENTBATTLER_CONCURRENCY=6 node bin/agentbattler.mjs run --manifest agents/pi-model-suite/manifest.json --positions benchmark/positions/v2.json --pairing cross-model --output results/pi-model-suite/matches --no-smoke",
    "replay:pi-suite": "node bin/agentbattler.mjs replay results/pi-model-suite/matches/result.json",
    "generate:claude-code-suite": "node scripts/generate-claude-code-suite.mjs",
    "validate:claude-code-suite": "node bin/agentbattler.mjs validate --manifest agents/claude-code-model-suite/manifest.json --positions benchmark/positions/v2.json --pairing cross-model",
    "benchmark:claude-code-suite": "AGENTBATTLER_CONCURRENCY=6 node bin/agentbattler.mjs run --manifest agents/claude-code-model-suite/manifest.json --positions benchmark/positions/v2.json --pairing cross-model --output results/claude-code-model-suite/matches --no-smoke",
    "replay:claude-code-suite": "node bin/agentbattler.mjs replay results/claude-code-model-suite/matches/result.json",
    "dotagents:image": "docker build --file harnesses/dotagents/Dockerfile --tag agentbattler-dotagents:8d4df16140e3 harnesses/dotagents",
    "generate:dotagents-suite": "node scripts/generate-dotagents-suite.mjs",
    "generate:dotagents-suite:smoke": "AGENTBATTLER_MODEL_FAMILIES=terra AGENTBATTLER_GENERATIONS_PER_MODEL=1 node scripts/generate-dotagents-suite.mjs",
    "generate:dotagents-suite:resume": "AGENTBATTLER_RESUME=1 node scripts/generate-dotagents-suite.mjs",
    "validate:dotagents-suite": "node bin/agentbattler.mjs validate --manifest agents/dotagents-model-suite/manifest.json --positions benchmark/positions/v2.json --pairing cross-model",
    "benchmark:dotagents-suite": "AGENTBATTLER_CONCURRENCY=6 node bin/agentbattler.mjs run --manifest agents/dotagents-model-suite/manifest.json --positions benchmark/positions/v2.json --pairing cross-model --output results/dotagents-model-suite/matches --no-smoke",
    "replay:dotagents-suite": "node bin/agentbattler.mjs replay results/dotagents-model-suite/matches/result.json",
    "league:place:dotagents": "node scripts/create-dotagents-placement.mjs",
    "league:run:dotagents": "node scripts/run-dotagents-placement.mjs",
    "build:harness-suite": "node scripts/build-harness-suite.mjs",
    "validate:harness-suite": "node bin/agentbattler.mjs validate --manifest agents/harness-suite/manifest.json --positions benchmark/positions/v2.json --pairing cross-harness-all",
    "benchmark:harness-suite": "AGENTBATTLER_CONCURRENCY=6 node bin/agentbattler.mjs run --manifest agents/harness-suite/manifest.json --positions benchmark/positions/v2.json --pairing cross-harness-all --output results/harness-suite/matches --no-smoke",
    "replay:harness-suite": "node bin/agentbattler.mjs replay results/harness-suite/matches/result.json",
    "terminal:matrix": "node scripts/build-terminal-schedule.mjs",
    "terminal:matrix:unbounded": "AGENTBATTLER_TERMINAL_MAX_WALL_TIME_MS=0 node scripts/build-terminal-schedule.mjs",
    "terminal:run": "node scripts/run-terminal-matrix.mjs",
    "terminal:run:all": "node scripts/run-terminal-matrix.mjs --adapter scripts/terminal-adapter-all.mjs",
    "terminal:run:parallel": "AGENTBATTLER_TERMINAL_CONCURRENCY=4 node scripts/run-terminal-matrix.mjs",
    "terminal:verify": "node scripts/verify-terminal-results.mjs"
  }
}
